generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:demo1234@localhost:5432/am_creator_analytics?schema=public"
}

model Account {
  id                String @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  User              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthenticityAudit {
  id             String         @id
  creatorId      String
  score          Decimal        @db.Decimal(5, 2)
  auditedAt      DateTime       @default(now())
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([score])
}

model BrandProfile {
  id                 String               @id
  userId             String               @unique
  tenantId           String?
  companyName        String
  industry           String?
  website            String?
  Tenant             Tenant?              @relation(fields: [tenantId], references: [id])
  User               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  Campaign           Campaign[]
  campaign_templates campaign_templates[]

  @@index([tenantId])
  @@index([userId])
}

model Campaign {
  id              String            @id
  brandId         String
  tenantId        String?
  title           String
  budget          Decimal           @db.Decimal(10, 2)
  startDate       DateTime
  endDate         DateTime
  status          CampaignStatus    @default(DRAFT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  BrandProfile    BrandProfile      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  Tenant          Tenant?           @relation(fields: [tenantId], references: [id])
  CampaignCreator CampaignCreator[]
  CampaignInvite  CampaignInvite[]
  Lead            Lead[]
  LinkedinUgcAd   LinkedinUgcAd[]

  @@index([brandId])
  @@index([status])
  @@index([tenantId])
}

model CampaignCreator {
  id             String         @id
  campaignId     String
  creatorId      String
  rate           Decimal        @db.Decimal(10, 2)
  paymentStatus  PaymentStatus  @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  Contract       Contract?

  @@unique([campaignId, creatorId])
  @@index([campaignId])
  @@index([creatorId])
}

model CampaignInvite {
  id             String         @id
  campaignId     String
  creatorId      String
  status         InviteStatus   @default(PENDING)
  Campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([creatorId])
}

model Contract {
  id                 String          @id
  campaignCreatorId  String          @unique
  status             ContractStatus  @default(DRAFT)
  openSignDocumentId String?         @unique
  openSignUrl        String?
  signedAt           DateTime?
  bonusPaidAt        DateTime?
  bonusAmount        Decimal?        @db.Decimal(10, 2)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime
  CampaignCreator    CampaignCreator @relation(fields: [campaignCreatorId], references: [id], onDelete: Cascade)

  @@index([campaignCreatorId])
  @@index([status])
}

model CreatorProfile {
  id                   String                @id
  userId               String                @unique
  tenantId             String?
  displayName          String
  bio                  String?
  niche                String?
  website              String?
  followerCount        Int                   @default(0)
  engagementRate       Decimal               @default(0) @db.Decimal(5, 2)
  gstin                String?
  panNumber            String?
  stateCode            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  AuthenticityAudit    AuthenticityAudit[]
  CampaignCreator      CampaignCreator[]
  CampaignInvite       CampaignInvite[]
  Tenant               Tenant?               @relation(fields: [tenantId], references: [id])
  User                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  Lead                 Lead[]
  LinkedinUgcAd        LinkedinUgcAd[]
  PayoutAccount        PayoutAccount[]
  SocialAccount        SocialAccount[]
  creator_verification creator_verification?
  payment_methods      payment_methods[]

  @@index([tenantId])
  @@index([userId])
}

model Lead {
  id             String          @id
  campaignId     String
  creatorId      String
  email          String?
  stage          LeadStage       @default(MQL)
  source         LeadSource      @default(CREATOR_POST)
  firstTouchAt   DateTime        @default(now())
  originalEmail  String?
  touchPoint     Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  Campaign       Campaign        @relation(fields: [campaignId], references: [id])
  CreatorProfile CreatorProfile  @relation(fields: [creatorId], references: [id])
  TrackingEvent  TrackingEvent[]

  @@index([campaignId])
  @@index([creatorId])
  @@index([email])
  @@index([originalEmail])
}

model LinkedinUgcAd {
  id             String         @id
  campaignId     String
  creatorId      String
  adCode         String         @unique
  status         String         @default("PENDING")
  Campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([adCode])
  @@index([campaignId])
  @@index([creatorId])
}

model PayoutAccount {
  id                String              @id
  creatorId         String
  provider          PaymentProvider
  status            String              @default("PENDING")
  CreatorProfile    CreatorProfile      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  PayoutTransaction PayoutTransaction[]

  @@index([creatorId])
  @@index([provider])
}

model PayoutTransaction {
  id                String                  @id
  payoutAccountId   String
  amount            Decimal                 @db.Decimal(10, 2)
  status            PayoutTransactionStatus @default(PENDING)
  commissionRate    Decimal?                @db.Decimal(5, 2)
  attributedRevenue Decimal?                @db.Decimal(12, 2)
  PayoutAccount     PayoutAccount           @relation(fields: [payoutAccountId], references: [id], onDelete: Cascade)

  @@index([payoutAccountId])
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SocialAccount {
  id             String         @id
  creatorId      String
  platform       SocialPlatform
  username       String?
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([creatorId, platform])
  @@index([creatorId])
}

model SupportTicket {
  id          String         @id
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)

  @@index([status])
}

model Tenant {
  id                   String           @id
  name                 String
  type                 TenantType       @default(AGENCY)
  tenant_domain_unique String?          @unique
  createdAt            DateTime         @default(now())
  updatedAt            DateTime
  BrandProfile         BrandProfile[]
  Campaign             Campaign[]
  CreatorProfile       CreatorProfile[]
  User                 User[]
}

model TrackingEvent {
  id            String   @id
  leadId        String?
  campaignId    String?
  creatorId     String?
  type          String
  timestamp     DateTime @default(now())
  originalEmail String?
  Lead          Lead?    @relation(fields: [leadId], references: [id])

  @@index([campaignId])
  @@index([leadId])
  @@index([originalEmail])
}

model User {
  id               String          @id
  name             String?
  email            String?         @unique
  emailVerified    DateTime?
  role             UserRole        @default(CREATOR)
  tenantId         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime
  twoFactorEnabled Boolean         @default(false)
  twoFactorSecret  String?
  backupCodes      String?
  Account          Account[]
  BrandProfile     BrandProfile?
  CreatorProfile   CreatorProfile?
  Session          Session[]
  Tenant           Tenant?         @relation(fields: [tenantId], references: [id])
  push_tokens      push_tokens[]

  @@index([email])
  @@index([tenantId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model campaign_templates {
  id            String        @id
  name          String
  description   String?
  category      String
  budget        Decimal       @db.Decimal(10, 2)
  duration      Int
  requirements  Json?
  niche         String?
  minFollowers  Int           @default(0)
  minEngagement Decimal       @default(0) @db.Decimal(5, 2)
  brandId       String?
  isPublic      Boolean       @default(false)
  usedCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime
  BrandProfile  BrandProfile? @relation(fields: [brandId], references: [id])
}

model creator_verification {
  id             String             @id
  creatorId      String             @unique
  idType         String
  idNumber       String
  idFrontUrl     String
  idBackUrl      String?
  idVerified     Boolean            @default(false)
  bankName       String?
  accountNumber  String?
  ifscCode       String?
  upiId          String?
  bankVerified   Boolean            @default(false)
  videoUrl       String?
  videoVerified  Boolean            @default(false)
  status         VerificationStatus @default(PENDING)
  verifiedAt     DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime
  CreatorProfile CreatorProfile     @relation(fields: [creatorId], references: [id])
}

model payment_methods {
  id             String         @id
  creatorId      String
  type           PaymentType
  upiId          String?
  bankName       String?
  accountNumber  String?
  ifscCode       String?
  isDefault      Boolean        @default(false)
  verified       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  CreatorProfile CreatorProfile @relation(fields: [creatorId], references: [id])
}

model push_tokens {
  id        String   @id
  token     String   @unique
  platform  String
  deviceId  String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User     @relation(fields: [userId], references: [id])

  @@unique([deviceId, userId])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED_BY_CREATOR
  SIGNED_BY_BRAND
  FULLY_EXECUTED
  EXPIRED
  TERMINATED
}

enum ContractType {
  STANDARD
  EXCLUSIVE
  USAGE_RIGHTS
  NDA
  IP_TRANSFER
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REVISION_NEEDED
  COMPLETED
}

enum DeliverableType {
  POST
  STORY
  REEL
  VIDEO
  BLOG
  TWEET
  LIVE
  OTHER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum LeadSource {
  CREATOR_POST
  CREATOR_STORY
  CREATOR_VIDEO
  DIRECT_LINK
  UGC_AD_CODE
  OTHER
}

enum LeadStage {
  MQL
  SQL
  OPPORTUNITY
  CLOSED_WON
  CLOSED_LOST
}

enum NotificationType {
  CAMPAIGN_INVITE
  CAMPAIGN_UPDATE
  PAYMENT_RECEIVED
  MILESTONE_REACHED
  SYSTEM
  COMPLIANCE_ALERT
  AUTHENTICITY_FLAG
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  CASHFREE
  WIRE_TRANSFER
  UPI
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
}

enum PaymentType {
  UPI
  BANK_TRANSFER
  RAZORPAY
}

enum PayoutTransactionStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum SocialPlatform {
  YOUTUBE
  LINKEDIN
  INSTAGRAM
  TIKTOK
  TWITTER
  FACEBOOK
}

enum TaxFormStatus {
  NOT_SUBMITTED
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TaxFormType {
  W9
  W8BEN
  FORM26AS
}

enum TenantType {
  AGENCY
  BRAND
  ENTERPRISE
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum UserRole {
  SUPER_ADMIN
  AGENCY
  BRAND
  CREATOR
  ADMIN
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}
