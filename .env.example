# ============================================
# AM Creator Analytics - Local Development Example
# Copy to .env.local or .env and replace every placeholder value.
# ============================================

# ---- Public App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-local-nextauth-secret

# ---- Postgres / App Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-local-postgres-password
POSTGRES_DB=postgres
APP_DB_NAME=am_creator_analytics
APP_DB_USER=am_creator_app
APP_DB_PASSWORD=replace-with-local-app-db-password
DATABASE_URL=postgresql://am_creator_app:replace-with-local-app-db-password@localhost:5432/am_creator_analytics?schema=public

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Mongo / OpenSign ----
MONGO_INITDB_ROOT_USERNAME=opensign
MONGO_INITDB_ROOT_PASSWORD=replace-with-local-opensign-mongo-password
OPENSIGN_MONGO_DATABASE=opensign
OPENSIGN_MONGODB_URI=mongodb://opensign:replace-with-local-opensign-mongo-password@localhost:27017/opensign?authSource=admin
OPENSIGN_SERVER_URL=http://localhost:3001/app
OPENSIGN_URL=http://localhost:3001
OPENSIGN_APP_ID=opensign
OPENSIGN_MASTER_KEY=replace-with-local-opensign-master-key
OPENSIGN_SESSION_TOKEN=replace-with-local-opensign-session-token

# ---- Nango ----
NANGO_DB_NAME=nango
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=replace-with-local-nango-db-password
NANGO_BASE_URL=http://localhost:3005
NANGO_SERVER_URL=http://localhost:3005
NEXT_PUBLIC_NANGO_BASE_URL=http://localhost:3005
NEXT_PUBLIC_NANGO_UI_URL=http://localhost:3006
NANGO_CALLBACK_URL=http://localhost:3005/oauth/callback
NANGO_FRONTEND_URL=http://localhost:3006
NANGO_ENVIRONMENT=development
NANGO_SECRET_KEY=replace-with-local-nango-secret-key
NANGO_ENCRYPTION_KEY=replace-with-local-nango-encryption-key
NANGO_ADMIN_KEY=replace-with-local-nango-admin-key

# ---- Social OAuth ----
INSTAGRAM_CLIENT_ID=replace-with-instagram-client-id
INSTAGRAM_CLIENT_SECRET=replace-with-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/callback/instagram
YOUTUBE_CLIENT_ID=replace-with-youtube-client-id
YOUTUBE_CLIENT_SECRET=replace-with-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/callback
LINKEDIN_CLIENT_ID=replace-with-linkedin-client-id
LINKEDIN_CLIENT_SECRET=replace-with-linkedin-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/linkedin/callback

# ---- Payments ----
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# ---- Messaging / Notifications ----
RESEND_API_KEY=replace-with-resend-api-key
WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-whatsapp-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-whatsapp-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret

# ---- Storage / Optional Services ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=replace-with-local-minio-access-key
MINIO_SECRET_KEY=replace-with-local-minio-secret-key
MINIO_BUCKET=am-creator-uploads
MINIO_PUBLIC_URL=http://localhost:9000
MEILI_MASTER_KEY=replace-with-local-meili-master-key
