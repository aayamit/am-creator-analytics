# ============================================
# AM Creator Analytics - Production Example
# Copy to .env.prod and replace every placeholder value.
# Internal container-to-container hosts should stay as service names.
# ============================================

# ---- Public App URLs ----
NEXT_PUBLIC_APP_URL=https://www.amcreatoranalytics.com
NEXTAUTH_URL=https://www.amcreatoranalytics.com
NEXTAUTH_SECRET=replace-with-production-nextauth-secret

# ---- Postgres / App Database ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-production-postgres-password
POSTGRES_DB=postgres
APP_DB_NAME=am_creator_analytics
APP_DB_USER=am_creator_app
APP_DB_PASSWORD=replace-with-production-app-db-password
DATABASE_URL=postgresql://am_creator_app:replace-with-production-app-db-password@postgres:5432/am_creator_analytics?schema=public

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Mongo / OpenSign ----
MONGO_INITDB_ROOT_USERNAME=opensign
MONGO_INITDB_ROOT_PASSWORD=replace-with-production-opensign-mongo-password
OPENSIGN_MONGO_DATABASE=opensign
OPENSIGN_MONGODB_URI=mongodb://opensign:replace-with-production-opensign-mongo-password@mongo:27017/opensign?authSource=admin
OPENSIGN_SERVER_URL=http://opensign:3000/app
OPENSIGN_URL=https://opensign.amcreatoranalytics.com
OPENSIGN_APP_ID=opensign
OPENSIGN_MASTER_KEY=replace-with-production-opensign-master-key
OPENSIGN_SESSION_TOKEN=replace-with-production-opensign-session-token

# ---- Nango ----
NANGO_DB_NAME=nango
NANGO_DB_USER=nango
NANGO_DB_PASSWORD=replace-with-production-nango-db-password
NANGO_BASE_URL=http://nango:3000
NANGO_SERVER_URL=http://nango:3000
NEXT_PUBLIC_NANGO_BASE_URL=https://nango.amcreatoranalytics.com
NEXT_PUBLIC_NANGO_UI_URL=https://nango-ui.amcreatoranalytics.com
NANGO_CALLBACK_URL=https://nango.amcreatoranalytics.com/oauth/callback
NANGO_FRONTEND_URL=https://nango-ui.amcreatoranalytics.com
NANGO_ENVIRONMENT=production
NANGO_SECRET_KEY=replace-with-production-nango-secret-key
NANGO_ENCRYPTION_KEY=replace-with-production-nango-encryption-key
NANGO_ADMIN_KEY=replace-with-production-nango-admin-key

# ---- Social OAuth ----
INSTAGRAM_CLIENT_ID=replace-with-instagram-client-id
INSTAGRAM_CLIENT_SECRET=replace-with-instagram-client-secret
INSTAGRAM_REDIRECT_URI=https://www.amcreatoranalytics.com/api/auth/callback/instagram
YOUTUBE_CLIENT_ID=replace-with-youtube-client-id
YOUTUBE_CLIENT_SECRET=replace-with-youtube-client-secret
YOUTUBE_REDIRECT_URI=https://www.amcreatoranalytics.com/api/youtube/callback
LINKEDIN_CLIENT_ID=replace-with-linkedin-client-id
LINKEDIN_CLIENT_SECRET=replace-with-linkedin-client-secret
LINKEDIN_REDIRECT_URI=https://www.amcreatoranalytics.com/api/linkedin/callback

# ---- Payments ----
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# ---- Messaging / Notifications ----
RESEND_API_KEY=replace-with-resend-api-key
WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-whatsapp-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace-with-whatsapp-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-whatsapp-webhook-verify-token
WHATSAPP_APP_SECRET=replace-with-whatsapp-app-secret

# ---- Storage / Optional Services ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=replace-with-production-minio-access-key
MINIO_SECRET_KEY=replace-with-production-minio-secret-key
MINIO_BUCKET=am-creator-uploads
MINIO_PUBLIC_URL=https://assets.amcreatoranalytics.com
MEILI_MASTER_KEY=replace-with-production-meili-master-key

# ---- Deployment ----
CLOUDFLARE_TUNNEL_ID=replace-with-cloudflare-tunnel-id
